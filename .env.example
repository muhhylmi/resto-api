# App
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=86400

# Database (local)
# for prisma schema
DATABASE_URL="mysql://root:rootpassword@localhost:3306/restaurant_db"
# for prisma client
DATABASE_USER="root"
DATABASE_PASSWORD="password"
DATABASE_NAME="resto-api"
DATABASE_HOST="127.0.0.1"
DATABASE_PORT=3307

# Docker MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=restaurant_db
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword
